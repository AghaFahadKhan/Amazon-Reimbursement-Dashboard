# ═══════════════════════════════════════════════════════════════
# Rename this file to `secrets.toml` and edit the credentials below.
# DO NOT commit `secrets.toml` to Git — only commit this example file.
# On Streamlit Cloud, paste these contents into App Settings → Secrets.
# ═══════════════════════════════════════════════════════════════

[users]
# Format:   username = "password"
# Add one line per person you want to give access to.

admin       = "change-this-strong-password"
agha    = "agha-secret-123"
teammate1   = "pick-a-long-random-string"
teammate2   = "another-unique-password"

# ── How to add more users ───────────────────────────────────────
# 1. Pick a username (no spaces)
# 2. Pick a strong unique password
# 3. Add a new line:   newuser = "their-password"
# 4. Save the file and restart the app (or re-deploy on Streamlit Cloud)
